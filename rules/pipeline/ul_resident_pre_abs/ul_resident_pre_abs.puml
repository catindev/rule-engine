@startuml
title ul_resident_pre_abs - UL resident: проверки ДО госреестров и ДО АБС (demo)
skinparam shadowing false
skinparam roundcorner 14
skinparam ActivityBorderColor #444444
skinparam ActivityFontColor #111111
skinparam ActivityBackgroundColor #F7F7F7
skinparam ActivityBackgroundColor<<ERR>> #FFB3B3
skinparam ActivityBorderColor<<ERR>> #B30000
skinparam ActivityBackgroundColor<<WARN>> #FFE8A3
skinparam ActivityBorderColor<<WARN>> #A07A00
skinparam ActivityBackgroundColor<<EXC>> #FF6B6B
skinparam ActivityBorderColor<<EXC>> #7A0000
skinparam ActivityFontColor<<EXC>> #111111
skinparam ActivityFontStyle<<EXC>> bold
skinparam ActivityBackgroundColor<<PRED>> #DDDDDD
skinparam ActivityBorderColor<<PRED>> #777777
skinparam ActivityBackgroundColor<<LIB>> #C9F0EA
skinparam ActivityBorderColor<<LIB>> #0F6B62
skinparam ActivityBackgroundColor<<ERR_LIB>> #BFECE5
skinparam ActivityBorderColor<<ERR_LIB>> #B30000
skinparam ActivityBackgroundColor<<WARN_LIB>> #BFECE5
skinparam ActivityBorderColor<<WARN_LIB>> #A07A00
skinparam ActivityBackgroundColor<<EXC_LIB>> #BFECE5
skinparam ActivityBorderColor<<EXC_LIB>> #7A0000
skinparam ActivityFontStyle<<EXC_LIB>> bold
skinparam ActivityBackgroundColor<<OK>> #F7F7F7
start
partition "Beneficiary" {
:Передан тип бенефициара (иначе нельзя выбрать набор проверок)\n[beneficiary.type] not_empty; <<EXC>>
:Тип бенефициара допустим\n[beneficiary.type] in_dictionary; <<EXC>>
}
partition "FATCA" {
:Флаг обязателен: beneficiary.isPassiveNFE\n[fatca.passive] not_empty; <<ERR>>
:Если beneficiary.isPassiveNFE=Y маркер для upstream\n[fatca.passive] equals; <<ERR>>
:Флаг обязателен: beneficiary.hasForeignControllingPersons\n[fatca.cpforeign] not_empty; <<ERR>>
:Если beneficiary.hasForeignControllingPersons=Y маркер для upstream\n[fatca.cpforeign] equals; <<ERR>>
:Флаг обязателен: beneficiary.isUSPerson\n[fatca.ustaxpayer] not_empty; <<ERR>>
:Если beneficiary.isUSPerson=Y маркер для upstream\n[fatca.ustaxpayer] equals; <<ERR>>
:Флаг обязателен: beneficiary.hasUSControllingPersons\n[fatca.cpus] not_empty; <<ERR>>
:Если beneficiary.hasUSControllingPersons=Y маркер для upstream\n[fatca.cpus] equals; <<ERR>>
}
partition "Beneficiary" {
:ИНН заполнен\n[beneficiary.inn] not_empty; <<ERR>>
:ИНН: 10 цифр, не из одинаковых цифр\n[beneficiary.inn] matches_regex; <<ERR_LIB>>
:ИНН: контрольный разряд\n[beneficiary.inn] valid_inn; <<ERR_LIB>>
}
partition "Identity" {
:Наименование ЮЛ (полное, рус.) заполнено\n[name.full] not_empty; <<ERR>>
:ОПФ заполнено\n[org.form] not_empty; <<ERR>>
}
partition "Address" {
:predicate: jurisdiction == RU\n[addr.country] equals; <<PRED>>
if ("Если юрисдикция РФ проверить ОГРН\nwhen: pred_jurisdiction_is_ru") then (true)
  :ОГРН заполнен\n[beneficiary.ogrn] not_empty; <<ERR>>
  :ОГРН: 13 цифр, не из нулей\n[beneficiary.ogrn] matches_regex; <<ERR>>
  :ОГРН: контрольный разряд\n[beneficiary.ogrn] valid_ogrn; <<ERR>>
else (false)
endif
:Адрес: addr.country заполнен\n[addr.country] not_empty; <<ERR>>
:Адрес: addr.region заполнен\n[addr.region] not_empty; <<ERR>>
:Адрес: addr.city заполнен\n[addr.city] not_empty; <<ERR>>
:Адрес: addr.street заполнен\n[addr.street] not_empty; <<ERR>>
:Адрес: addr.house заполнен\n[addr.house] not_empty; <<ERR>>
:Адрес: addr.zip заполнен\n[addr.zip] not_empty; <<ERR>>
}
partition "Status" {
:Идентификатор основания участия (если передан) заполнен\n[part.basis] not_empty; <<WARN>>
}
partition "Other" {
:Заполнен хотя бы один контакт (телефон или email)\n[contacts] any_filled; <<ERR_LIB>>
}
partition "Tax" {
:Признак иностранного налогового резидентства передан\n[tax.foreign] not_empty; <<ERR>>
:predicate: tax.isForeignTaxResident == Y\n[tax.foreign] equals; <<PRED>>
if ("Если иностранный налоговый резидент = Y обязательны поля 14-16\nwhen: pred_is_foreign_tax_yes") then (true)
  :Страна налогового резидентства заполнена\n[tax.country] not_empty; <<ERR>>
  :TIN заполнен\n[tax.tin] not_empty; <<ERR>>
  :Foreign address: faddr.country заполнен\n[faddr.country] not_empty; <<ERR>>
  :Foreign address: faddr.city заполнен\n[faddr.city] not_empty; <<ERR>>
  :Foreign address: faddr.street заполнен\n[faddr.street] not_empty; <<ERR>>
  :Foreign address: faddr.house заполнен\n[faddr.house] not_empty; <<ERR>>
else (false)
endif
}
partition "Status" {
:Дата приобретения статуса заполнена\n[part.start] not_empty; <<ERR>>
:Дата приобретения статуса: формат YYYY-MM-DD\n[part.start] matches_regex; <<ERR>>
:predicate: agreement.statusEndDate not empty\n[part.end] not_empty; <<PRED>>
if ("Если передана дата прекращения проверить диапазон\nwhen: pred_status_end_not_empty") then (true)
  :Дата прекращения статуса (если передана): формат YYYY-MM-DD\n[part.end] matches_regex; <<ERR>>
  :Дата прекращения статуса > даты начала\n[part.end] field_greater_than_field; <<ERR>>
else (false)
endif
}
stop
@enduml
