    {
      "type": "condition",
      "description": "Выполнять 3DS-проверки только если threeDS.requested=true",
      "when": "pred_is_3ds_required",
      "steps": [
        {
          "rule": "rule_3ds_method_required"
        },
        {
          "rule": "rule_3ds_method_allowed"
        }
      ],
      "id": "checkout_main.threeds_validate.condition_3ds_required"
    },
    {
      "type": "pipeline",
      "description": "Checkout: проверки 3DS (выполняются только если requested=true)",
      "strict": false,
      "flow": [
        {
          "condition": "condition_3ds_required"
        }
      ],
      "id": "checkout_main.threeds_validate"
    },
    {
      "type": "rule",
      "role": "predicate",
      "description": "Признак необходимости 3DS",
      "field": "threeDS.requested",
      "operator": "equals",
      "value": true,
      "meta": {
        "why": "3DS-проверки нужны только при включенном флаге",
        "bt": "DEMO: checkout/3ds"
      },
      "id": "checkout_main.threeds_validate.pred_is_3ds_required"
    },
    {
      "type": "rule",
      "description": "Метод 3DS должен быть одним из разрешённых (NONE,3DS1,3DS2)",
      "level": "ERROR",
      "code": "ERR_3DS_METHOD_INVALID",
      "message": "Недопустимый метод 3DS",
      "field": "threeDS.method",
      "operator": "in_dictionary",
      "dictionary": {
        "type": "static",
        "id": "three_ds_methods"
      },
      "meta": {
        "why": "Защита от мусорных значений",
        "bt": "DEMO: checkout/3ds"
      },
      "role": "check",
      "id": "checkout_main.threeds_validate.rule_3ds_method_allowed"
    },
    {
      "type": "rule",
      "description": "Метод 3DS должен быть указан",
      "level": "ERROR",
      "code": "ERR_3DS_METHOD_REQUIRED",
      "message": "Не указан метод 3DS",
      "field": "threeDS.method",
      "operator": "not_empty",
      "meta": {
        "why": "Для 3DS2 важно понимать выбранный протокол",
        "bt": "DEMO: checkout/3ds"
      },
      "role": "check",
      "id": "checkout_main.threeds_validate.rule_3ds_method_required"
    },
    {
      "id": "pipeline_main",
      "type": "pipeline",
      "description": "Демо: основной пайплайн, запускающий валидацию checkout",
      "strict": false,
      "flow": [
        {
          "pipeline": "checkout_main"
        }
      ]
    },
    {
      "type": "condition",
      "description": "Выполнить доп.проверку только если все qty > 0",
      "when": "pred_all_qty_positive",
      "steps": [
        {
          "rule": "rule_max_qty_le_100"
        }
      ],
      "id": "wildcard_agg_demo.condition_all_qty_positive"
    },
    {
      "type": "condition",
      "description": "Выполнить проверку MIN только если есть >=2 товаров с qty>5",
      "when": "pred_count_qty_gt_5_ge_2",
      "steps": [
        {
          "rule": "rule_min_qty_positive"
        }
      ],
      "id": "wildcard_agg_demo.condition_count_qty_gt_5_ge_2"
    },
    {
      "type": "pipeline",
      "description": "Демо: wildcard + агрегации (EACH/ALL/COUNT/MIN/MAX)",
      "strict": false,
      "flow": [
        {
          "rule": "rule_each_qty_positive"
        },
        {
          "condition": "condition_all_qty_positive"
        },
        {
          "condition": "condition_count_qty_gt_5_ge_2"
        },
        {
          "rule": "rule_min_qty_positive"
        }
      ],
      "id": "wildcard_agg_demo"
    },
    {
      "type": "rule",
      "role": "predicate",
      "description": "Все qty > 0 (ALL)",
      "field": "checkout.items[*].qty",
      "operator": "greater_than",
      "value": 0,
      "aggregate": {
        "mode": "ALL",
        "onEmpty": "FALSE"
      },
      "id": "wildcard_agg_demo.pred_all_qty_positive"
    },
    {
      "type": "rule",
      "role": "predicate",
      "description": "Хотя бы 2 товара с qty > 5 (COUNT >= 2)",
      "field": "checkout.items[*].qty",
      "operator": "greater_than",
      "value": 5,
      "aggregate": {
        "mode": "COUNT",
        "op": ">=",
        "value": 2,
        "onEmpty": "FALSE"
      },
      "id": "wildcard_agg_demo.pred_count_qty_gt_5_ge_2"
    },
    {
      "type": "rule",
      "role": "check",
      "description": "qty каждого товара должен быть > 0 (EACH: issue на каждый провал)",
      "field": "checkout.items[*].qty",
      "operator": "greater_than",
      "value": 0,
      "level": "ERROR",
      "code": "ERR_ITEM_QTY_POSITIVE",
      "message": "Количество товара должно быть больше 0",
      "id": "wildcard_agg_demo.rule_each_qty_positive"
    },
    {
      "type": "rule",
      "role": "check",
      "description": "MAX(qty) должен быть < 100 (MAX)",
      "field": "checkout.items[*].qty",
      "operator": "less_than",
      "value": 100,
      "aggregate": {
        "mode": "MAX",
        "onEmpty": "PASS"
      },
      "level": "WARNING",
      "code": "WARN_MAX_QTY_LT_100",
      "message": "Слишком большое количество товара",
      "id": "wildcard_agg_demo.rule_max_qty_le_100"
    },
    {
      "type": "rule",
      "role": "check",
      "description": "MIN(qty) должен быть > 0 (MIN)",
      "field": "checkout.items[*].qty",
      "operator": "greater_than",
      "value": 0,
      "aggregate": {
        "mode": "MIN",
        "onEmpty": "PASS"
      },
      "level": "ERROR",
      "code": "ERR_MIN_QTY_POSITIVE",
      "message": "Минимальное количество товара должно быть больше 0",
      "id": "wildcard_agg_demo.rule_min_qty_positive"
    }
  ]
}