    {
      "type": "rule",
      "description": "Срок действия карты должен быть в формате MM/YY",
      "level": "ERROR",
      "code": "ERR_CARD_EXP_FORMAT",
      "message": "Неверный формат срока действия карты",
      "field": "card.exp",
      "operator": "matches_regex",
      "value": "^(0[1-9]|1[0-2])\\/[0-9]{2}$",
      "meta": {
        "why": "Проверка формата срока действия до попытки авторизации",
        "bt": "DEMO: checkout/card",
        "hint": "Ожидается формат MM/YY, например 12/29"
      },
      "role": "check",
      "id": "library.card.exp_mm_yy"
    },
    {
      "type": "rule",
      "description": "PAN должен состоять из 16 цифр",
      "level": "ERROR",
      "code": "ERR_CARD_PAN_FORMAT",
      "message": "Неверный формат номера карты (PAN)",
      "field": "card.pan",
      "operator": "matches_regex",
      "value": "^\\d{16}$",
      "meta": {
        "why": "Минимальная транспортная проверка формата PAN до любых интеграций",
        "bt": "DEMO: checkout/base",
        "hint": "Проверьте, что клиент ввёл 16 цифр без пробелов"
      },
      "role": "check",
      "id": "library.card.pan_16_digits"
    },
    {
      "type": "rule",
      "description": "Email обязателен",
