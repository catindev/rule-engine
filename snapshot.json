      "value": 0,
      "level": "ERROR",
      "code": "ERR_TXN_AMOUNT_NOT_POSITIVE",
      "message": "Сумма транзакции должна быть больше нуля",
      "id": "accounts_validation.checks.rule_txn_amount_positive"
    },
    {
      "type": "rule",
