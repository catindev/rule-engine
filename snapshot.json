      "field": "customer.email",
      "operator": "not_empty",
      "meta": {
        "why": "Email нужен для отправки чека/уведомлений и для последующих коммуникаций",
        "bt": "DEMO: checkout/base",
        "hint": "Запросите email у клиента"
      },
      "role": "check",
      "id": "library.common.email_required"
    },
    {
